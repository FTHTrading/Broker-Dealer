# ═══════════════════════════════════════════════════════════════════════
# FTH Trading — Broker-Dealer Platform
# Environment Configuration Template
# ═══════════════════════════════════════════════════════════════════════
# Copy this file to .env.local for development or .env.production
# NEVER commit actual secrets to version control
# ═══════════════════════════════════════════════════════════════════════

# ── Application ──────────────────────────────────────────────────────
NODE_ENV=development
LOG_LEVEL=debug
PORT=8080

# ── Database ─────────────────────────────────────────────────────────
DATABASE_URL=postgresql://fth_user:changeme@localhost:5432/broker_dealer
DATABASE_POOL_MIN=5
DATABASE_POOL_MAX=20
DATABASE_SSL=false

# ── Redis ────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_CLUSTER_ENABLED=false

# ── Kafka ────────────────────────────────────────────────────────────
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=broker-dealer-dev
KAFKA_GROUP_ID=broker-dealer-group

# ── Authentication ───────────────────────────────────────────────────
AUTH_JWT_SECRET=your-jwt-secret-min-256-bits
AUTH_JWT_EXPIRATION=3600
AUTH_MFA_ENABLED=true
AUTH_OIDC_ISSUER=https://auth.fthtrading.com

# ── HashiCorp Vault ──────────────────────────────────────────────────
VAULT_ADDR=http://localhost:8200
VAULT_TOKEN=your-vault-token
VAULT_NAMESPACE=broker-dealer

# ── FIX Protocol ─────────────────────────────────────────────────────
FIX_SENDER_COMP_ID=FTHTRADING
FIX_TARGET_COMP_ID=EXCHANGE
FIX_HOST=localhost
FIX_PORT=9876
FIX_HEARTBEAT_INTERVAL=30

# ── Market Data ──────────────────────────────────────────────────────
MARKET_DATA_PROVIDER=simulated
BLOOMBERG_API_KEY=
REFINITIV_API_KEY=

# ── Risk Engine ──────────────────────────────────────────────────────
RISK_VAR_CONFIDENCE=0.99
RISK_MAX_POSITION_SIZE=1000000
RISK_MAX_DAILY_LOSS=500000

# ── Compliance ───────────────────────────────────────────────────────
NET_CAPITAL_MINIMUM=250000
NET_CAPITAL_EARLY_WARNING_RATIO=1.2
CUSTOMER_PROTECTION_RESERVE_BANK=

# ── AML / OFAC ───────────────────────────────────────────────────────
OFAC_SDN_LIST_URL=https://www.treasury.gov/ofac/downloads/sdn.csv
AML_ALERT_THRESHOLD=10000
AML_SAR_AUTO_FILE=false

# ── Regulatory Reporting ─────────────────────────────────────────────
CAT_REPORTER_ID=
TRACE_MPID=
FINRA_API_KEY=
SEC_EDGAR_CIK=

# ── Observability ────────────────────────────────────────────────────
DATADOG_API_KEY=
DATADOG_APP_KEY=
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_SERVICE_NAME=broker-dealer

# ── Digital Assets (Optional) ────────────────────────────────────────
FIREBLOCKS_API_KEY=
FIREBLOCKS_API_SECRET_PATH=
BITGO_ACCESS_TOKEN=
BITGO_ENTERPRISE_ID=
